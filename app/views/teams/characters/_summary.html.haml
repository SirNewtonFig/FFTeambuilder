:ruby
  selected ||= false

.container.py-2.pr-2.sm:pl-1.cursor-pointer.hover:bg-gray-700.text-gray-300.hover:text-white.rounded-sm.border-r-4.border-transparent{ id: "character-#{i}", class: ('bg-gray-700 border-r-blue-600' if selected) }
  %input{ type: 'hidden', name: 'chars[]', value: i }
  .flex.relative
    .sprite.scale-125.sm:scale-150{ style: sprite_style_for(team, char.job, char.sex)}

    .w-4.absolute.bottom-0.-right-3.sm:relative.sm:w-36.ml-1.text-white.flex.flex-col.justify-end
      .text-sm.truncate.hidden.sm:block #{char.name}
      .text-sm.hidden.sm:block JP: #{char.jp_total}
      .flex.mt-1.items-center.justify-between
        .items-center.hidden.sm:flex
          = inline_svg_tag("zodiacs/#{char.zodiac}.svg", class: 'h-4 w-4')
          .ml-1.text-sm.truncate= char.zodiac.titleize
        - if @char && @char != char
          - compat = compat_between(@char, char)
          - puts compat
          .flex.flex-col
            = inline_svg_tag("icons/#{compat}.svg", class: "flex-1 h-4 w-4 #{compat_class(compat)}", title: "#{compat.titleize} compatibility")

